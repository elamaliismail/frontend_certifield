# URL du webhook du workflow "Auth" sur la plateforme Agentic AI
# ex: https://xxx.app.n8n.cloud/webhook/auth
VITE_AUTH_WEBHOOK_URL=

# URL publique du serveur MCP (mcp-server/, tunnelé via ngrok) qui reçoit le
# callback des workflows et que le front-end interroge pour le résultat
# ex: https://xxxx-xx-xx-xx-xx.ngrok-free.app
VITE_AUTH_CALLBACK_URL=

# URL des webhooks du workflow "Patient" (liste et création)
# Tant qu'elles ne sont pas configurées, la page Patients retombe sur des
# données de démonstration locales.
VITE_PATIENTS_LIST_WEBHOOK_URL=
VITE_PATIENTS_CREATE_WEBHOOK_URL=

# URL des webhooks du workflow "Medical Record" (lecture et mise à jour)
# Tant qu'elles ne sont pas configurées, la page Dossier retombe sur des
# données de démonstration locales.
VITE_MEDICAL_RECORD_WEBHOOK_URL=
VITE_MEDICAL_RECORD_UPDATE_WEBHOOK_URL=

# URL des webhooks du workflow "Document". Tant qu'elles ne sont pas
# configurées, la page Dossier retombe sur des données de démonstration
# locales.
# - LIST : liste des documents rattachés à un patient
# - EXTRACT : lance une extraction (1er essai = JigsawStack, "Réessayer" =
#   Gemini 2.5 Flash puis Mistral, voir l'écran du document)
# - VALIDATE : bouton "Accepter" — ajoute les champs extraits au dossier
#   médical du patient et marque le document comme validé
# - SIGN : bouton "Signer" (après "Accepter") — signature électronique
#   finale, verrouille le document (statut "signe")
VITE_DOCUMENTS_LIST_WEBHOOK_URL=
VITE_DOCUMENT_EXTRACT_WEBHOOK_URL=
VITE_DOCUMENT_VALIDATE_WEBHOOK_URL=
VITE_DOCUMENT_SIGN_WEBHOOK_URL=

# URL du webhook du workflow "Document" (file d'attente multi-patients) —
# alimente les écrans "Documents" (menu) et "Validation" (menu), à la
# différence de VITE_DOCUMENTS_LIST_WEBHOOK_URL qui liste les documents d'UN
# seul patient déjà connu (dossier médical).
VITE_DOCUMENTS_QUEUE_WEBHOOK_URL=

# URL du webhook du workflow "Ask about this patient" (RAG patient).
# Réponse attendue minimale : { "answer": "..." }
VITE_PATIENT_QA_WEBHOOK_URL=

# Les consultations (lecture ET écriture) n'utilisent PAS de webhook — le
# front-end appelle directement /consultations sur le serveur MCP (voir
# VITE_AUTH_CALLBACK_URL ci-dessus), comme pour l'upload de document. Pas de
# raisonnement IA nécessaire pour une simple lecture/écriture.
